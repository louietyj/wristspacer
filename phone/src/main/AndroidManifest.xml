<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Needed so the system allows us to call SmartspaceManager.createSmartspaceSession().
         protectionLevel=development means pm grant (ADB/Shizuku) can grant it at runtime.
         We declare it here so the system registers the permission on install. -->
    <uses-permission
        android:name="android.permission.ACCESS_SMARTSPACE"
        tools:ignore="ProtectedPermissions" />

    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Exempts this app from Doze / battery optimisation so the foreground
         service and Data Layer pushes aren't deferred while the phone is idle. -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- Wearable Data Layer -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <application
        android:name=".WristspacerApp"
        android:label="Wristspacer"
        android:icon="@android:drawable/ic_dialog_info"
        android:supportsRtl="true"
        android:theme="@style/Theme.Wristspacer">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".SmartspaceBridgeService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- Shizuku provider — lets Shizuku bind to our process -->
        <provider
            android:name="rikka.shizuku.ShizukuProvider"
            android:authorities="${applicationId}.shizuku"
            android:multiprocess="false"
            android:enabled="true"
            android:exported="true"
            android:permission="android.permission.INTERACT_ACROSS_USERS_FULL" />

        <!-- Receives /request_update messages from the watch complication -->
        <service
            android:name=".PhoneWearListenerService"
            android:exported="true">
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.MESSAGE_RECEIVED" />
                <data
                    android:scheme="wear"
                    android:host="*" />
            </intent-filter>
        </service>

        <!-- Auto-starts the bridge after phone reboot -->
        <receiver
            android:name=".BootReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

    </application>

</manifest>

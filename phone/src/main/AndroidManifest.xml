<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Needed so the system allows us to call SmartspaceManager.createSmartspaceSession().
         protectionLevel=development means pm grant (ADB/Shizuku) can grant it at runtime.
         We declare it here so the system registers the permission on install. -->
    <uses-permission
        android:name="android.permission.ACCESS_SMARTSPACE"
        tools:ignore="ProtectedPermissions" />

    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <!-- Wearable Data Layer -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <application
        android:name=".WristspacerApp"
        android:label="Wristspacer"
        android:icon="@android:drawable/ic_dialog_info"
        android:supportsRtl="true"
        android:theme="@style/Theme.Wristspacer">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".SmartspaceBridgeService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- Shizuku provider — lets Shizuku bind to our process -->
        <provider
            android:name="rikka.shizuku.ShizukuProvider"
            android:authorities="${applicationId}.shizuku"
            android:multiprocess="false"
            android:enabled="true"
            android:exported="true"
            android:permission="android.permission.INTERACT_ACROSS_USERS_FULL" />

    </application>

</manifest>
